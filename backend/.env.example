# FastAPI — MySQL (phpMyAdmin / XAMPP)
# Kurulum: bu dosyayı kopyalayın →  copy .env.example .env  (Windows)
# Gerçek şifre ve veritabanı adınızı .env içinde doldurun (.env Git'e gitmez).

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=finance_tracker

# Optional: AI merchant name from receipt OCR (OpenAI). Leave empty to use OCR-only heuristics.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
